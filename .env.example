# ========================================================================
#  Plan Attainment · KH · Plantilla de variables de entorno
# ------------------------------------------------------------------------
#  Copia este fichero a `.env` y rellena los valores reales.
#  No subir el `.env` al repositorio (está en `.gitignore`).
# ========================================================================

# ───────────── App ─────────────
# APP_ENV=production         # production | staging | local
# APP_DEBUG=false            # true expone trazas y errores; false las oculta
APP_ENV=production
APP_DEBUG=false

# ───────────── MAPEX (SQL Server) ─────────────
DB_MAPEX_HOST=
DB_MAPEX_NAME=
DB_MAPEX_USER=
DB_MAPEX_PASS=

# ───────────── Sage (SQL Server) — opcional, no se usa actualmente ─────────────
DB_SAGE_HOST=
DB_SAGE_NAME=
DB_SAGE_USER=
DB_SAGE_PASS=

# ───────────── PostgreSQL (mantenimiento preventivo) ─────────────
DB_PG_HOST=127.0.0.1
DB_PG_PORT=5432
DB_PG_NAME=plan_attainment
DB_PG_USER=
DB_PG_PASS=
DB_PG_SCHEMA=public

# ───────────── Planificación (Excel diario) ─────────────
# Carpeta (local o de red) donde están los Excel de planificación diaria.
EXCEL_BASE_PATH="/ruta/a/Planificaciones diarias"

# ───────────── Mantenimiento ─────────────
MANT_USE_PG=true
# Ruta (local o de red) al Excel de órdenes de mantenimiento preventivo.
MANT_XLSX_PATH="/ruta/al/Ordenes_Mant_Prev.xlsx"

# ───────────── Credenciales mantenimiento ─────────────
# Las contraseñas se almacenan como hash bcrypt. Para generar:
#   php -r "echo password_hash('LA_PASSWORD', PASSWORD_BCRYPT), PHP_EOL;"
# Si APP_ENV=production y estas variables están vacías, el login NO funciona.
MANT_TECNICO_USER=
MANT_TECNICO_PASS_HASH=
MANT_OPERARIO_USER=
MANT_OPERARIO_PASS_HASH=
